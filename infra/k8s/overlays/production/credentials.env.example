# Copie para credentials.env (não versionar) e preencha com valores reais.
# Formato: uma variável por linha (compatível com secretGenerator do Kustomize).
#
# A connection string deve usar o mesmo postgres-password abaixo.
postgres-password=ALTERE_SENHA_FORTE_POSTGRES
rabbitmq-password=ALTERE_SENHA_FORTE_RABBITMQ
keycloak-admin-password=ALTERE_SENHA_ADMIN_KEYCLOAK
cashflow-connection-string=Host=postgres;Port=5432;Database=cashflow_db;Username=postgres;Password=ALTERE_SENHA_FORTE_POSTGRES
