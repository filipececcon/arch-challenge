{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TransactionRegistered",
  "description": "Event published by the CashFlow service when a financial transaction is successfully registered.",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "payload"],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the event. Used to guarantee idempotency on the consumer side."
    },
    "eventType": {
      "type": "string",
      "const": "TransactionRegistered",
      "description": "Event type. Used for routing and future versioning."
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Moment the event occurred, in UTC (ISO 8601)."
    },
    "payload": {
      "type": "object",
      "required": ["transactionId", "type", "amount"],
      "properties": {
        "transactionId": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier of the transaction in the CashFlow service."
        },
        "type": {
          "type": "string",
          "enum": ["CREDIT", "DEBIT"],
          "description": "Transaction type."
        },
        "amount": {
          "type": "number",
          "minimum": 0.01,
          "description": "Transaction amount in BRL. Must be positive."
        },
        "description": {
          "type": "string",
          "maxLength": 255,
          "description": "Optional description of the transaction."
        }
      }
    }
  },
  "example": {
    "eventId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
    "eventType": "TransactionRegistered",
    "occurredAt": "2026-04-03T10:00:00Z",
    "payload": {
      "transactionId": "9b1deb4d-3b7d-4bad-9bdd-2b0d7b3dcb6d",
      "type": "CREDIT",
      "amount": 150.00,
      "description": "Cash sale"
    }
  }
}
