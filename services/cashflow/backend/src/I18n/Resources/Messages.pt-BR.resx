<?xml version="1.0" encoding="utf-8"?>
<root>
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:element name="root" msdata:IsDataSet="true">
      <xsd:complexType>
        <xsd:choice maxOccurs="unbounded">
          <xsd:element name="data">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" type="xsd:string" minOccurs="0" msdata:Ordinal="1" />
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string" use="required" />
              <xsd:attribute name="xml:space" use="optional" />
            </xsd:complexType>
          </xsd:element>
        </xsd:choice>
      </xsd:complexType>
    </xsd:element>
  </xsd:schema>
  <resheader name="resmimetype">
    <value>text/microsoft-resx</value>
  </resheader>
  <resheader name="version">
    <value>2.0</value>
  </resheader>
  <resheader name="reader">
    <value>System.Resources.ResXResourceReader, System.Windows.Forms</value>
  </resheader>
  <resheader name="writer">
    <value>System.Resources.ResXResourceWriter, System.Windows.Forms</value>
  </resheader>

  <!-- Mensagens de exceção -->
  <data name="Exception_InternalError" xml:space="preserve">
    <value>Ocorreu um erro interno. Por favor, tente novamente.</value>
  </data>
  <data name="Exception_ValidationError" xml:space="preserve">
    <value>Um ou mais erros de validação ocorreram.</value>
  </data>
  <data name="Exception_DomainError" xml:space="preserve">
    <value>Uma violação de regra de negócio ocorreu.</value>
  </data>

  <!-- Mensagens de validação -->
  <data name="Validation_TransactionType_Invalid" xml:space="preserve">
    <value>Tipo de transação inválido. Use Crédito ou Débito.</value>
  </data>
  <data name="Validation_Amount_GreaterThanZero" xml:space="preserve">
    <value>O valor deve ser maior que zero.</value>
  </data>
  <data name="Validation_Description_MaxLength" xml:space="preserve">
    <value>A descrição não pode exceder 255 caracteres.</value>
  </data>
  <data name="Validation_Transaction_NotFound" xml:space="preserve">
    <value>Transação '{0}' não encontrada.</value>
  </data>
</root>

