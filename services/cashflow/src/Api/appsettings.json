{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Elasticsearch",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Elastic.Apm": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/cashflow",
    "Audience": "cashflow-api",
    "RequireHttpsMetadata": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=cashflow_db;Username=postgres;Password=postgres",
    "MongoConnection":   "mongodb://cashflow:cashflow@localhost:27017?authSource=cashflow_read",
    "RedisConnection":   "localhost:6379"
  },
  "MongoDB": {
    "Database": "cashflow_read"
  },
  "RabbitMQ": {
    "Host":     "localhost",
    "Username": "rabbit",
    "Password": "rabbit"
  },
  "OutboxWorker": {
    "PollingIntervalSeconds": 5,
    "BatchSize": 50,
    "MaxRetries": 5,
    "CollectionMap": {
      "TransactionProcessed": "transactions"
    }
  },
  "ElasticApm": {
    "ServerUrl": "http://localhost:8200",
    "ServiceName": "cashflow-api",
    "ServiceVersion": "1.0.0",
    "Environment": "Production",
    "TransactionSampleRate": 1.0,
    "CaptureBody": "errors",
    "LogLevel": "Error"
  }
}
