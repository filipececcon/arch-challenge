{
  "Security": {
    "Disabled": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "ElasticsearchLogging": {
    "NodeUri": "http://localhost:9200",
    "Username": "elastic",
    "Password": "changeme",
    "IndexFormat": "dashboard-api"
  },
  "ElasticApm": {
    "Environment": "Local"
  }
}
