{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Elasticsearch",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "ArchChallenge.Dashboard.Application": "Debug"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MongoConnection": "mongodb://dashboard:dashboard@localhost:27017/?authSource=admin"
  },
  "MongoDB": {
    "Database": "dashboard_read"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "rabbit",
    "Password": "rabbit"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/cashflow",
    "Audience": "dashboard-api",
    "RequireHttpsMetadata": false
  },
  "Security": {
    "Disabled": false
  },
  "ElasticsearchLogging": {
    "NodeUri": "",
    "Username": "",
    "Password": "",
    "IndexFormat": "dashboard-api"
  }
}
